datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String // "SUPER_ADMIN", "ADMIN", "EDITOR", "SALES", "VIEWER"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                        String   @id @default("default")
  logo                      String // URL or path to logo
  brandName                 String // "Art Vision"
  slogan                    String // "L’art au service de votre image."
  primaryColor              String // "#08051F"
  secondaryColor            String // "#1A1238"
  accentColor               String // "#6C2BD9"
  creativeMagenta           String // "#D72888"
  orangeCta                 String // "#FF6A00"
  softWhite                 String // "#F8F7FC"
  lightGray                 String // "#EDEAF5"
  textDark                  String // "#171625"
  socialFb                  String?
  socialIg                  String?
  socialIn                  String?
  socialTw                  String?
  email                     String // Contact email
  phone                     String // Contact phone
  whatsapp                  String // Contact whatsapp
  franceAddress             String // France address
  tunisiaAddress            String // Tunisia address
  googleAnalyticsId         String?
  googleTagManagerId        String?
  searchConsoleVerification String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model EmailSettings {
  id                        String   @id @default("default")
  primaryNotificationEmail  String   @default("contact@art-visions.fr")
  additionalRecipients      String   @default("[]")
  clientConfirmationEnabled Boolean  @default(true)
  enabledTypes              String   @default("[]")
  replyToVisitor            Boolean  @default(true)
  senderName                String   @default("Art Vision")
  senderEmail               String   @default("contact@art-visions.fr")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model EmailLog {
  id                String    @id @default(cuid())
  type              String
  recipient         String
  subject           String
  relatedEntityType String?
  relatedEntityId   String?
  status            String    @default("PENDING")
  providerMessageId String?
  errorMessageSafe  String?
  payloadJson       String    @default("{}")
  attemptCount      Int       @default(0)
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([relatedEntityType, relatedEntityId])
}

model Page {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  contentJson    String // Stores section contents / structure dynamically
  contentHtml    String    @default("")
  excerpt        String?
  layout         String    @default("FULL_WIDTH")
  status         String    @default("PUBLISHED")
  focusKeyword   String?
  isActive       Boolean   @default(true)
  seoTitle       String?
  seoDescription String?
  ogImage        String?
  canonicalUrl   String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Service {
  id             String           @id @default(cuid())
  slug           String           @unique
  name           String
  icon           String // e.g. "PenTool", "Video"
  image          String? // featured image
  heroTagline    String? // small label above the title, e.g. "L'Âme de Votre Marque"
  introHeading   String? // heading for the detailed section, e.g. "De l'idée à l'identité"
  description    String
  detailedBody   String // detailed description / explanation
  benefits       String // semicolon separated benefits or json list
  process        String // semicolon separated process steps or json list
  gallery        String           @default("[]") // JSON array of { url, alt } images (admin-managed)
  videos         String           @default("[]") // JSON array of { url, title } videos (admin-managed)
  customHtml     String? // admin-managed sanitized HTML block rendered on the page
  status         String           @default("PUBLISHED")
  seoTitle       String?
  seoDescription String?
  packages       PricingPackage[]
  faqs           FAQ[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PricingPackage {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String // "Basic", "Standard", "Premium"
  price     String // e.g. "à partir de 70€"
  features  String // semicolon separated features
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortfolioProject {
  id                String            @id @default(cuid())
  slug              String            @unique
  title             String
  client            String
  industry          String
  objective         String
  challenge         String
  solution          String
  result            String
  testimonial       String?
  testimonialRole   String?
  testimonialAuthor String?
  images            String // semicolon-separated URLs or json array
  videoUrl          String?
  customHtml        String?           // admin-managed sanitized HTML block
  status            String            @default("PUBLISHED")
  seoTitle          String?
  seoDescription    String?
  categoryId        String
  category          PortfolioCategory @relation(fields: [categoryId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model PortfolioCategory {
  id        String             @id @default(cuid())
  slug      String             @unique
  name      String
  projects  PortfolioProject[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model BlogPost {
  id                String       @id @default(cuid())
  slug              String       @unique
  title             String
  content           String // rich HTML body (or detailed outline for drafts)
  excerpt           String? // short summary for cards / meta fallback
  featuredImage     String
  featuredImageAlt  String? // alt text for the featured image
  imagePrompt       String? // generation prompt suggestion (editorial)
  author            String
  status            String // "DRAFT", "SCHEDULED", "PUBLISHED", "ARCHIVED"
  tags              String // comma-separated tags
  // SEO
  seoTitle          String?
  seoDescription    String?
  focusKeyword      String?
  secondaryKeywords String? // comma-separated
  ogTitle           String?
  ogDescription     String?
  ogImage           String?
  // Rich content modules
  faqJson           String? // JSON array of { question, answer }
  relatedServices   String? // comma-separated service slugs
  relatedTools      String? // comma-separated tool slugs
  relatedPortfolio  String? // comma-separated portfolio slugs
  ctaTitle          String?
  ctaText           String?
  ctaLabel          String?
  ctaHref           String?
  customHtml        String? // admin-managed sanitized HTML block rendered in the article
  // Scheduling
  publishedAt       DateTime?
  scheduledAt       DateTime?
  readingTime       Int          @default(5)
  views             Int          @default(0)
  isPillar          Boolean      @default(false)
  categoryId        String
  category          BlogCategory @relation(fields: [categoryId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([status])
  @@index([categoryId])
}

model BlogCategory {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  icon        String? // lucide icon name
  sortOrder   Int        @default(0)
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  name         String
  role         String
  rating       Int      @default(5)
  message      String
  image        String? // avatar image
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model QuoteRequest {
  id        String   @id @default(cuid())
  service   String
  details   String
  budget    String
  deadline  String
  fileUrl   String? // uploaded briefing/file
  name      String
  email     String
  phone     String
  company   String?
  consent   Boolean  @default(false)
  status    String   @default("NEW") // "NEW", "CONTACTED", "IN_PROGRESS", "WON", "LOST"
  notes     String? // Admin notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrintProduct {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String // e.g. "Flyers"
  description     String?
  image           String?
  active          Boolean       @default(true)
  mode            String        @default("instant") // "instant" | "quote"
  productionTime  String? // e.g. "3 à 5 jours ouvrés"
  deliveryTime    String?
  fileGuidelines  String?
  minQuantity     Int           @default(1)
  sides           String        @default("both") // "recto" | "recto-verso" | "both"
  vatNote         String?
  seoTitle        String?
  metaDescription String?
  sortOrder       Int           @default(0)
  options         PrintOption[]
  prices          PrintPrice[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PrintOption {
  id            String       @id @default(cuid())
  productId     String
  product       PrintProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  type          String // "paper" | "format" | "finish" | "side"
  name          String // display label, e.g. "A4", "350g Mat", "100"
  value         String       @default("") // slug used in the price matrix
  priceModifier Float        @default(0.0) // legacy; price matrix takes precedence
  active        Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([productId, type])
}

model CVTemplate {
  id          String        @id @default(cuid())
  name        String // "Creative Agency", "Modern Tech", "Executive Corporate"
  layout      String // JSON configuration of styling (colors, sizes, layout style)
  thumbnail   String?
  generatedCV GeneratedCV[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GeneratedCV {
  id          String     @id @default(cuid())
  templateId  String
  template    CVTemplate @relation(fields: [templateId], references: [id])
  name        String
  profession  String
  phone       String
  email       String
  address     String
  about       String
  skills      String // JSON array
  languages   String // JSON array
  experiences String // JSON array
  education   String // JSON array
  projects    String // JSON array
  photoUrl    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BusinessCardTemplate {
  id             String                  @id @default(cuid())
  name           String // "Modern Minimalist", "Creative Gradient", "Elegant Corporate"
  layout         String // JSON configuration
  thumbnail      String?
  generatedCards GeneratedBusinessCard[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model GeneratedBusinessCard {
  id         String               @id @default(cuid())
  templateId String
  template   BusinessCardTemplate @relation(fields: [templateId], references: [id])
  name       String
  jobTitle   String
  phone      String
  email      String
  address    String?
  website    String?
  socials    String? // JSON object/string
  logoUrl    String?
  qrData     String?
  colors     String? // Selected colors (JSON)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  url       String
  fileName  String   @default("")
  fileType  String? // old compat
  altText   String?
  title     String?
  caption   String?
  width     Int      @default(800)
  height    Int      @default(600)
  size      Int
  mimeType  String   @default("image/jpeg")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SEOSettings {
  id               String  @id @default("default")
  globalTitle      String?
  globalDesc       String?
  sitemapXml       String?
  robotsTxt        String?
  googleSearchCons String?

  // Page-specific SEO metadata
  pageType           String? // "GLOBAL", "SERVICE", "POST", "PROJECT", "PAGE", "SEO_LANDING"
  pageId             String?
  title              String?
  description        String?
  focusKeyword       String?
  secondaryKeywords  String?
  slug               String?  @unique
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?
  indexable          Boolean  @default(true)
  follow             Boolean  @default(true)
  schemaType         String?  @default("WebPage")
  customJsonLd       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Redirect {
  id         String   @id @default(cuid())
  fromPath   String?  @unique // old compat
  toPath     String? // old compat
  sourceUrl  String   @unique
  targetUrl  String
  statusCode Int      @default(301)
  active     Boolean  @default(true)
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FAQ {
  id            String   @id @default(cuid())
  pageType      String   @default("SERVICE") // "SERVICE", "POST", "PROJECT", "PAGE", "SEO_LANDING"
  pageId        String   @default("")
  question      String
  answer        String
  order         Int      @default(0)
  schemaEnabled Boolean  @default(true)
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoLandingPage {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  h1               String
  keyword          String
  city             String?
  pageType         String   @default("GENERIC") // "GENERIC", "LOCAL"
  intro            String
  content          String // Long copy blocks in HTML/text
  faq              String? // JSON string
  relatedServices  String? // comma-separated slugs
  relatedPortfolio String? // comma-separated slugs
  status           String   @default("PUBLISHED") // "DRAFT", "PUBLISHED"
  seoTitle         String?
  metaDescription  String?
  canonicalUrl     String?
  ogImage          String?
  indexable        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SitemapEntry {
  id              String   @id @default(cuid())
  url             String   @unique
  priority        Float    @default(0.5)
  changeFrequency String   @default("weekly")
  included        Boolean  @default(true)
  lastModified    DateTime @default(now())
}

// ──────────────────────────────────────────────────────────
// OUTILS GRATUITS (Free Tools) — lead capture & generations
// ──────────────────────────────────────────────────────────

// Generic store for every tool generation / lead.
model ToolSubmission {
  id               String   @id @default(cuid())
  toolType         String // "cv", "carte-de-visite", "qr-code", "palette", "brief-logo", "slogan", "bio-instagram", "caption-instagram", "flyer", "impression"
  userId           String? // optional logged-in admin owner
  email            String?
  name             String?
  phone            String?
  inputData        String   @default("{}") // JSON of the form inputs
  outputData       String   @default("{}") // JSON of the generated result
  consentMarketing Boolean  @default(false)
  status           String   @default("NEW") // "NEW", "CONTACTED", "QUALIFIED", "WON", "LOST"
  notes            String? // internal admin notes
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([toolType])
  @@index([status])
  @@index([createdAt])
}

// Admin-editable settings per tool (enable/disable, SEO, CTA, FAQ).
model ToolSetting {
  id              String   @id // = toolType slug, e.g. "qr-code"
  toolType        String   @unique
  title           String?
  shortDesc       String?
  ctaLabel        String?
  ctaHref         String?
  seoTitle        String?
  seoDescription  String?
  faqJson         String? // JSON array of {question, answer}
  relatedServices String? // comma separated service slugs
  isActive        Boolean  @default(true)
  indexable       Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Reusable templates / presets for tools (CV, card, flyer, QR, palette...).
model ToolTemplate {
  id           String   @id @default(cuid())
  toolType     String // "cv", "carte-de-visite", "flyer", "qr-code", "palette"
  title        String
  previewImage String?
  config       String   @default("{}") // JSON config (colors, layout...)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([toolType])
}

// Pricing rules powering the printing price calculator.
model PrintPriceRule {
  id           String   @id @default(cuid())
  productType  String // "flyers", "affiches", "baches", "panneaux", "catalogues", "cartes-de-visite"
  format       String   @default("") // "A6", "A5", "A4", "A3", custom...
  paperType    String   @default("") // "135g brillant", "350g mat"...
  finish       String   @default("") // "aucune", "pelliculage mat", "vernis"...
  side         String   @default("recto") // "recto", "recto-verso"
  quantityMin  Int      @default(1)
  quantityMax  Int      @default(1000000)
  priceBase    Float    @default(0) // fixed setup price for the bracket
  pricePerUnit Float    @default(0) // per-unit price
  leadTimeDays Int      @default(5)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productType])
}

// ──────────────────────────────────────────────────────────
// IMPRESSION & TARIFS — price matrix, orders, audit log
// All money is stored as INTEGER CENTS (never floats).
// (PrintProduct / PrintOption are defined earlier and extended.)
// ──────────────────────────────────────────────────────────

// Price matrix row: a unique combination → price in cents.
model PrintPrice {
  id             String       @id @default(cuid())
  productId      String
  product        PrintProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  paper          String       @default("")
  format         String       @default("")
  finish         String       @default("")
  side           String       @default("recto") // "recto" | "recto-verso"
  quantity       Int
  priceHtCents   Int          @default(0)
  priceTtcCents  Int          @default(0)
  costCents      Int?
  marginPct      Float?
  promoTtcCents  Int?
  productionDays Int          @default(5)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([productId, paper, format, finish, side, quantity])
  @@index([productId])
}

// Quote requests / orders coming from the public print calculator.
model PrintQuoteRequest {
  id                String   @id @default(cuid())
  productSlug       String
  productName       String?
  options           String   @default("{}") // JSON of chosen options
  estimatedTtcCents Int?
  name              String?
  email             String?
  phone             String?
  message           String?
  status            String   @default("NEW") // NEW|CONTACTED|CONFIRMED|IN_PRODUCTION|DELIVERED|CANCELLED
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Audit trail for price changes.
model PriceAuditLog {
  id        String   @id @default(cuid())
  productId String?
  action    String // "update" | "bulk_adjust" | "import" | "delete" | "create"
  detail    String   @default("") // human-readable summary
  user      String? // admin email
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────
// ANALYTICS — anonymous events + daily summaries
// ──────────────────────────────────────────────────────────
model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String   // page_view | service_view | tool_open | quote_form_submitted | whatsapp_click | cta_click ...
  pagePath   String   @default("")
  pageTitle  String?
  sessionId  String?
  visitorId  String?
  country    String?
  city       String?
  deviceType String?  // desktop | mobile | tablet
  browser    String?
  referrer   String?
  source     String?  // direct | organic | social | referral | paid | email
  medium     String?
  campaign   String?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
  @@index([visitorId])
}

model AnalyticsDailySummary {
  id                String   @id @default(cuid())
  date              DateTime @unique
  visitors          Int      @default(0)
  sessions          Int      @default(0)
  pageViews         Int      @default(0)
  newVisitors       Int      @default(0)
  returningVisitors Int      @default(0)
  quoteRequests     Int      @default(0)
  whatsappClicks    Int      @default(0)
  ctaClicks         Int      @default(0)
  toolGenerations   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Real visitor tracking — one row per day per page
model PageView {
  id        String   @id @default(cuid())
  path      String // e.g. "/", "/blog/some-post"
  date      DateTime // stored as start-of-day (UTC midnight)
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([path, date])
  @@index([date])
}
