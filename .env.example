# ── Local development ────────────────────────────────────────────────
# SQLite file used for local dev. Leave as-is.
DATABASE_URL="file:./dev.db"

# ── Production database — Turso (libSQL) ─────────────────────────────
# Create a DB at https://turso.tech then:
#   turso db show <name> --url        -> TURSO_DATABASE_URL
#   turso db tokens create <name>     -> TURSO_AUTH_TOKEN
# Leave these EMPTY locally (the app falls back to DATABASE_URL above).
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# ── Auth ─────────────────────────────────────────────────────────────
# Long random string (e.g. `openssl rand -base64 48`). REQUIRED in production.
JWT_SECRET="replace-with-a-long-random-secret"

# ── Public site URL (canonical URLs, sitemap, Open Graph) ────────────
NEXT_PUBLIC_APP_URL="https://your-domain.example"

# ── File uploads in production — Vercel Blob ─────────────────────────
# Create a Blob store in the Vercel dashboard and link it to the project; the
# token is injected automatically. Leave EMPTY locally (uploads -> public/uploads).
BLOB_READ_WRITE_TOKEN=""

# ── Optional: AI for slogan / bio / caption generators ───────────────
# If unset, the tools use the built-in template generator (no fake AI).
AI_API_KEY=""
AI_MODEL="claude-haiku-4-5"
